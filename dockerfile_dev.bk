FROM node:24-alpine

WORKDIR /app

# Dipendenze complete: ci serve anche prisma CLI a runtime
COPY package*.json ./
RUN npm ci

# Codice del backend
COPY . .

# Env di default per funzionare da solo
ENV NODE_ENV=development
ENV HTTPS=
ENV DATABASE_URL=file:./prisma/dev.db

# Directory usate dal progetto
RUN mkdir -p certs prisma uploads avatar/users dist/public

# Prisma client + build TS
RUN npx prisma generate
RUN npm run build

# File statici serviti da Fastify
RUN cp -r src/public/. dist/public/

# Script di avvio
RUN chmod +x ./deploy_dev.sh

EXPOSE 5000

CMD ["sh", "./deploy_dev.sh"]